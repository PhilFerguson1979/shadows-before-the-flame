<div id="installPrompt" class="install-prompt" style="display:none;">
  <span class="install-text">Add to home screen for quick access</span>
  <button id="installBtn" class="install-btn">Install</button>
  <button id="installDismiss" class="install-dismiss">&times;</button>
</div>

<script>
  let deferredPrompt: Event | null = null;
  const banner = document.getElementById('installPrompt');
  const installBtn = document.getElementById('installBtn');
  const dismissBtn = document.getElementById('installDismiss');

  window.addEventListener('beforeinstallprompt', (e: Event) => {
    e.preventDefault();
    deferredPrompt = e;
    if (localStorage.getItem('sbtf-install-dismissed')) return;
    if (banner) banner.style.display = 'flex';
  });

  installBtn?.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    (deferredPrompt as any).prompt();
    await (deferredPrompt as any).userChoice;
    deferredPrompt = null;
    if (banner) banner.style.display = 'none';
  });

  dismissBtn?.addEventListener('click', () => {
    if (banner) banner.style.display = 'none';
    localStorage.setItem('sbtf-install-dismissed', 'true');
  });

  window.addEventListener('appinstalled', () => {
    if (banner) banner.style.display = 'none';
    deferredPrompt = null;
  });
</script>

<style>
.install-prompt {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card, #181b24);
  border-top: 1px solid rgba(0,201,167,0.25);
  padding: 0.75rem 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  z-index: 90;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.5);
}
.install-text {
  flex: 1;
  color: var(--text-normal, #c4c7cc);
  font-size: 0.85rem;
  font-family: 'Inter', sans-serif;
}
.install-btn {
  padding: 0.4rem 1rem;
  background: var(--accent-primary, #00c9a7);
  color: #0b0b0d;
  border: none;
  border-radius: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: background 0.2s;
}
.install-btn:hover {
  background: #00e0bb;
}
.install-dismiss {
  background: none;
  border: none;
  color: var(--text-muted, #8a8e96);
  font-size: 1.2rem;
  cursor: pointer;
  padding: 0.25rem;
  line-height: 1;
}
.install-dismiss:hover { color: var(--text-normal, #c4c7cc); }
</style>
